# Backend
DATABASE_URL=postgresql+psycopg://app:app@db:5432/app
SESSION_SECRET=change-me-32-bytes-random
# Mark the session cookie Secure (set true in production behind HTTPS)
SESSION_HTTPS_ONLY=false
ENCRYPTION_KEY=        # generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
# Optional extra admin accounts, seeded at boot. Format: user1:pass1,user2:pass2
# (existing usernames are never overwritten; passwords must not contain ':' or ',')
EXTRA_ADMINS=
PREP_WINDOW_DAYS=8
DISPLAY_TIMEZONE=Europe/Berlin
# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
# Deploy (Phase 5)
APP_DOMAIN=assessment.example.com
